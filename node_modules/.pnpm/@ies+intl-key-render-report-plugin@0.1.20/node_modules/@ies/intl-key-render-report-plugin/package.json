{
  "name": "@ies/intl-key-render-report-plugin",
  "version": "0.1.20",
  "types": "./dist/types/index.d.ts",
  "jsnext:source": "./src/index.ts",
  "main": "./dist/lib/index.js",
  "module": "./dist/es/index.js",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node --max_old_space_size=8192 ./node_modules/eslint/bin/eslint.js --fix --color --cache --quiet"
    ],
    "*.{js,jsx,mjs,mjsx,cjs,cjsx}": [
      "node --max_old_space_size=8192 ./node_modules/eslint/bin/eslint.js --fix --color --cache --quiet"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "dist/",
    "coverage/",
    "edenx.config.ts"
  ],
  "devDependencies": {
    "@byted/eslint-config-standard": "^3.1.1",
    "@byted/eslint-config-standard-react": "^2.1.1",
    "@byted/eslint-config-standard-ts": "^3.1.1",
    "@edenx/module-tools": "1.62.1",
    "@edenx/storybook": "1.62.1",
    "@storybook/addon-essentials": "^7",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "~4.2.1",
    "fake-indexeddb": "~6.0.0",
    "i18next": "~24.0.2",
    "idb-keyval": "~6.2.1",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "lint-staged": "~13.1.0",
    "prettier": "~2.8.1",
    "react": "^17",
    "react-dom": "^17",
    "react-json-pretty": "~2.2.0",
    "rimraf": "~3.0.2",
    "simple-git-hooks": "^2.11.1",
    "ts-jest": "~29.2.6",
    "tslib": "~2.8.1",
    "typescript": "~5.0.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://bnpm.byted.org/"
  },
  "scripts": {
    "build-storybook": "storybook build",
    "storybook": "storybook dev -p 6007",
    "dev": "edenx dev",
    "build": "edenx build",
    "build:watch": "NODE_ENV=development edenx build -w",
    "reset": "npx rimraf ./**/node_modules",
    "lint": "edenx lint",
    "lint:error": "edenx lint --quiet",
    "change": "edenx change",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js -c jest.config.js",
    "bump": "edenx bump",
    "pre": "edenx pre",
    "release": "edenx release",
    "gen-release-note": "edenx gen-release-note",
    "new": "edenx new",
    "upgrade": "edenx upgrade"
  }
}