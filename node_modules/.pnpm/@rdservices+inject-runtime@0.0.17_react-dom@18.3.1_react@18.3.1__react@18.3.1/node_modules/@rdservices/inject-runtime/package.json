{
  "name": "@rdservices/inject-runtime",
  "version": "0.0.17",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bundle": {
      "types": "./dist/bundle/index.d.ts",
      "require": "./dist/bundle/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "typescript": "^5.8.2",
    "uuid": "~11.1.0",
    "@rdservices/function": "0.1.3",
    "@byted/hooks": "^2.55.1",
    "solid-js": "^1.9.2"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^1.4.2",
    "@rsbuild/plugin-solid": "^1.0.6",
    "@rslib/core": "^0.9.1",
    "@rsbuild/plugin-less": "~1.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@rsbuild/plugin-babel": "^1.0.6",
    "vue": "^3.5.12"
  },
  "scripts": {
    "build": "rslib build && rushx build:bundle",
    "build:bundle": "rslib build -c rslib.config.boundle.ts",
    "dev:bundle": "rushx build:bundle --watch > tsc.log 2>&1 &",
    "dev": "rslib build --watch > tsc.log 2>&1 &",
    "predev": "rushx dev:bundle"
  }
}